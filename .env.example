# ====== X Layer Network ======
XLAYER_RPC=https://rpc.xlayer.tech

# ====== FirmaCompany Contract ======
FIRMA_COMPANY_ADDRESS=0x16660b4f71cb9e908ad672fdc4da1ac9be7e5722

# ====== USDT on X Layer ======
# Note: Two USDT contracts exist on X Layer:
# - 0x1E4a5963aBFD975d8c9021ce480b42188849D41d (bridged USDT, used for agent operations)
# - 0x779ded0c9e1022225f8e0630b35a9b54be713736 (native USDT, used for x402 + Uniswap V3)
USDT_ADDRESS=0x1E4a5963aBFD975d8c9021ce480b42188849D41d

# ====== Uniswap V3 on X Layer (official deployment) ======
UNISWAP_ROUTER=0x7078c4537c04c2b2e52ddba06074dbdacf23ca15

# ====== Agent Wallets (OKX Agentic Wallet / TEE) ======
# All signing via `onchainos wallet contract-call` — private keys managed by TEE.
# ACCOUNT_ID is the OKX Agentic Wallet identifier.
# ADDRESS is the on-chain wallet address.

MAIN_WALLET_ADDRESS=0x...
MAIN_WALLET_ACCOUNT_ID=your-main-account-uuid

RESEARCH_WALLET_ADDRESS=0x...
RESEARCH_WALLET_ACCOUNT_ID=your-research-account-uuid

EXECUTOR_WALLET_ADDRESS=0x...
EXECUTOR_WALLET_ACCOUNT_ID=your-executor-account-uuid

TREASURY_WALLET_ADDRESS=0x...
TREASURY_WALLET_ACCOUNT_ID=your-treasury-account-uuid

OPS_WALLET_ADDRESS=0x...
OPS_WALLET_ACCOUNT_ID=your-ops-account-uuid

# ====== Legacy: Private Key Fallback (not recommended) ======
# Only used if OKX Agentic Wallet is unavailable.
# MAIN_WALLET_PRIVATE_KEY=
# RESEARCH_WALLET_PRIVATE_KEY=
# EXECUTOR_WALLET_PRIVATE_KEY=
# TREASURY_WALLET_PRIVATE_KEY=
# OPS_WALLET_PRIVATE_KEY=

# ====== OKX / Onchain OS API ======
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
ONCHAINOS_API_URL=https://www.okx.com/api/v5

# ====== x402 Payment Protocol ======
X402_PORT=3001
X402_SIGNAL_PRICE=$0.01
X402_SCHEME=exact
X402_SYNC_SETTLE=false
X402_PAYMENT_TOKEN=0x779ded0c9e1022225f8e0630b35a9b54be713736

# Dedicated payment signer for x402 micropayments (EIP-3009 typed data signing).
# Main agent wallets use TEE (onchainos) — TEE does not support EIP-712.
# This key holds only a small USDT balance for signal purchases ($0.01/signal).
# Generate: cast wallet new | grep "Private key"
# Fund: send 0.1 USDT + 0.001 OKB for gas
X402_PAYMENT_PRIVATE_KEY=

# ====== Monitoring ======
MONITOR_POOLS=0x63d62734847e55a266fca4219a9ad0a02d5f6e02
SIGNAL_ENDPOINT=http://localhost:3001/signal
MONITOR_INTERVAL_MS=60000
EVALUATION_INTERVAL_MS=3600000
EXECUTOR_INTERVAL_MS=60000

# ====== LLM Decision Engine (optional — falls back to rule-based engine) ======
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ====== Debug ======
DEBUG=false
